{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"jsx": "react-jsx",
		"skipLibCheck": true,
		"noEmit": true,
		"paths": {
			"@vendetta/*": ["./node_modules/vendetta-types/src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
